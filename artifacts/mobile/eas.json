      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://dahinchu-agni.onrender.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
