# ─────────────────────────────────────────────────────────────────────────────
# Dahinchu Agni Ministries — Environment Variables
#
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend (API Server) ─────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
SESSION_SECRET=change-me-to-a-long-random-string

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# Required if using DB features (events, prayer requests, etc.)
DATABASE_URL=postgresql://user:password@localhost:5432/dahinchu-agni

# ── Push Notifications (VAPID) ───────────────────────────────────────────────
# Generate a fresh key pair with:
#   node -e "const wp=require('web-push');const k=wp.generateVAPIDKeys();console.log(k)"
#
# VAPID_PUBLIC_KEY  → used by the API server (web-push library)
# VAPID_PRIVATE_KEY → used by the API server (keep secret)
# VAPID_SUBJECT     → a mailto: or https: URL identifying you
#
VAPID_PUBLIC_KEY=BHZyeOdVhv-Zxegln3snXlljH9eSanMDI_9QthL0Yi-P1KFGX1pmmf2-aFAuIkbeYsUuH6O1lsJX494Hm3NPpng
VAPID_PRIVATE_KEY=3aQDqRRWaxSzEXkl4mh9lcyinscqdNpVshVqcezuDpg
VAPID_SUBJECT=mailto:info@dahinchuagni.com

# ── Mobile App ───────────────────────────────────────────────────────────────
# Set this to your deployed API server URL for production native builds.
# The mobile app uses this as the base URL for all API calls.
# Example: https://your-api-server.com
EXPO_PUBLIC_API_URL=

# For local dev with Expo Go, the API port defaults to 8080.
# Override if your API server runs on a different port:
# EXPO_PUBLIC_API_PORT=8080

# For static build deployment, set the public domain where the build is served:
EXPO_PUBLIC_DOMAIN=

# ── Expo EAS (for native iOS/Android builds) ─────────────────────────────────
# Create a free account at https://expo.dev, run `eas init` in artifacts/mobile/,
# then paste the project ID into artifacts/mobile/app.json → extra.eas.projectId
# EAS_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
