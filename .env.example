# ─────────────────────────────────────────────────────────────────────────────
# Dahinchu Agni Ministries — Standalone Environment Variables
#
# Copy this file to .env and fill in your values.
# On Replit, these are set via the Secrets/Env Vars panel — no .env file needed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-long-random-string

# ── API Server port (default: 8080) ───────────────────────────────────────────
# PORT=8080

# ── Push Notifications (VAPID) ────────────────────────────────────────────────
# Generate a fresh key pair with:
#   node -e "const wp=require('web-push');const k=wp.generateVAPIDKeys();console.log(k)"
#
# Set VAPID_PUBLIC_KEY  → used by the API server (web-push library)
# Set VAPID_PRIVATE_KEY → used by the API server (keep secret)
# Set VITE_VAPID_PUBLIC_KEY → same value as VAPID_PUBLIC_KEY, exposed to the
#                             browser at build time by Vite (not secret)
# Set VAPID_SUBJECT     → a mailto: or https: URL identifying you
#
VAPID_PUBLIC_KEY=BHZyeOdVhv-Zxegln3snXlljH9eSanMDI_9QthL0Yi-P1KFGX1pmmf2-aFAuIkbeYsUuH6O1lsJX494Hm3NPpng
VAPID_PRIVATE_KEY=3aQDqRRWaxSzEXkl4mh9lcyinscqdNpVshVqcezuDpg
VITE_VAPID_PUBLIC_KEY=BHZyeOdVhv-Zxegln3snXlljH9eSanMDI_9QthL0Yi-P1KFGX1pmmf2-aFAuIkbeYsUuH6O1lsJX494Hm3NPpng
VAPID_SUBJECT=mailto:info@dahinchuagni.com

# ── Mobile (Expo) push notifications ─────────────────────────────────────────
# Set this if you want Expo push tokens to register from native (iOS/Android).
# Must be a full URL, e.g. https://your-deployed-api.com
# EXPO_PUBLIC_API_URL=https://your-api-domain.com

# ── Expo EAS project (for native push on iOS/Android) ─────────────────────────
# Create a free account at https://expo.dev, run `eas init` in artifacts/mobile/,
# then paste the project ID into artifacts/mobile/app.json → extra.eas.projectId
# EAS_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
